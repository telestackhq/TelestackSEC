# Database Connection
DATABASE_URL="postgresql://user:password@localhost:5432/signal_sdk_db"

# Master encryption key (used to encrypt all stored keys)
# Must be 32 characters minimum
MASTER_KEY="your-secure-master-key-here-min-32-chars"

# Optional configuration
LOG_LEVEL="info"
MAX_PREKEYS=50
PREKEYS_THRESHOLD=20
SESSION_EXPIRY_DAYS=90
